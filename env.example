# Скопируйте в .env и задайте значения.
# OPENAI_API_KEY — ключ API OpenAI (LLM, embeddings на будущих шагах).
OPENAI_API_KEY=

# Модель для очистки сырой транскрипции на шаге 6.1.
OPENAI_CLEAN_TRANSCRIPT_MODEL=gpt-4.1-mini

# Локальная транскрибация через faster-whisper.
# Для RTX 4080 SUPER используйте cuda + float16.
LOCAL_STT_MODEL=large-v3
LOCAL_STT_DEVICE=cuda
LOCAL_STT_COMPUTE_TYPE=float16

# ru фиксирует русский язык; оставьте пустым для автоопределения.
LOCAL_STT_LANGUAGE=ru

# VAD отсекает тишину и снижает hallucination в начале/паузах.
LOCAL_STT_VAD_FILTER=true
LOCAL_STT_MIN_SILENCE_MS=700

# SQLite; путь относительно рабочей директории backend при запуске.
DATABASE_URL=sqlite:///./data/app.db

# Хранение данных приложения.
STORAGE_PATH=./data

# Готовые экспорты (DOCX, PNG и т.д.).
EXPORT_PATH=./exports

# Временные файлы (загрузка видео, аудио, кадры).
TEMP_PATH=./temp

# URL API для React (Vite, переменные с префиксом VITE_).
# Сборка Docker frontend использует тот же адрес, что и браузер: localhost:8005.
VITE_API_BASE_URL=http://localhost:8005
